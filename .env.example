# Copy this file to ".env" and fill in the values.

# Discord bot token. Get one from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here

# Global bot administrators: comma-separated Discord user IDs. These users can
# run every admin command in any server. The application owner is always an admin.
# BOT_ADMINS=123456789012345678,234567890123456789

# Path to the SQLite database for per-guild settings (DJ role, default volume).
# Under Docker, point this at a mounted volume so settings survive restarts.
# SONGKISSER_DB=songkisser.db

# GitHub repo (for the docker-compose image tag). Must be lowercase for GHCR.
# Resolves to ghcr.io/<GITHUB_REPOSITORY>:latest
GITHUB_REPOSITORY=protoser/songkisser
