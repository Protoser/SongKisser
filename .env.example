# Copy this file to ".env" and fill in the values.

# Discord bot token. Get one from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here

# Optional: a separate token used by the dev compose file (docker-compose.dev.yml)
# so you can test against a throwaway bot. Falls back to DISCORD_TOKEN if unset.
# DISCORD_TOKEN_DEV=your-dev-bot-token-here

# GitHub repo (for the docker-compose image tag). Must be lowercase for GHCR.
# Resolves to ghcr.io/<GITHUB_REPOSITORY>:latest
GITHUB_REPOSITORY=protoser/songkisser
